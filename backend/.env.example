SUPABASE_URL=https://your-project.supabase.co
# Server-side: use service_role secret so inserts pass RLS (dashboard → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-here
# Optional fallback (anon/publishable cannot insert into RLS-protected tables)
SUPABASE_KEY=your-anon-key-here
ADMIN_KEY=your-admin-key-here
RPC_URL=https://sepolia.base.org
# Comma-separated origins for CORS (Vercel app + optional local dev)
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# Real-time indexer: public Base has no reliable WSS; use Alchemy WSS or poll-only:
# INDEXER_WS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# INDEXER_POLL_FALLBACK_SECONDS=3
